		"@types/node": "^25.6.1",
		"@types/sharp": "^0.32.0",
		"@types/web-bluetooth": "^0.0.21",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"drizzle-kit": "^0.31.10",
